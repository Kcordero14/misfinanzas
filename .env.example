# Copiá este archivo a ".env" y completá los valores reales.
# Nunca subas el archivo ".env" (con tus secretos reales) a git ni lo compartas.

# Supabase → Project Settings → Database → Connection string (modo "URI")
DATABASE_URL=

# Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Cualquier texto largo inventado por vos, usado para firmar la sesión de Flask
FLASK_SECRET_KEY=

# Google Cloud Console → credenciales OAuth de tipo "Aplicación web"
# (dejalos vacíos si todavía no vas a usar la sincronización con Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
